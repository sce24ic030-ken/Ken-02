# KEN AI Robot Server - Environment Variables
# Set these in Render Dashboard → Environment

# Server (Render sets PORT automatically)
# PORT=10000

# ── MULTI-KEY ROTATION (unlimited free requests) ──
# Comma-separated keys = auto-rotate when one hits rate limit
# Example: GROQ_API_KEYS=key1,key2,key3
# Each Groq key = 14,400/day. 3 keys = 43,200/day!

# Groq — used for STT (speech-to-text) AND AI chat
# Get keys: https://console.groq.com/keys  (create multiple accounts)
GROQ_API_KEYS=

# Gemini — backup AI chat
# Get keys: https://aistudio.google.com/app/apikey
GEMINI_API_KEYS=

# DeepSeek — optional, very cheap
# Get key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Robot Identity
ROBOT_NAME=KEN
CREATOR_NAME=
